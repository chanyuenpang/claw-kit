{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/session-start-bootstrap.mjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\hooks\\session-start-bootstrap.mjs\"",
            "statusMessage": "Loading .claw session context"
          }
        ]
      }
    ]
  }
}
