{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "claw hook auto-claw --host codex",
            "commandWindows": "claw hook auto-claw --host codex",
            "statusMessage": "auto-claw: loading plan context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claw hook auto-doc --host codex",
            "commandWindows": "claw hook auto-doc --host codex",
            "timeout": 30,
            "statusMessage": "auto-doc: capturing plan report"
          }
        ]
      }
    ]
  }
}
