{
  "name": "@veewo/claw",
  "version": "0.1.18",
  "type": "module",
  "description": "Publishable claw CLI for .claw project bootstrap, planning, search, truth ingestion, and completion refresh.",
  "homepage": "https://github.com/chanyuenpang/claw-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/chanyuenpang/claw-kit.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "claw": "./dist/cli.js"
  },
  "dependencies": {
    "@veewo/claw-core": "0.1.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/**/*.test.js"
  }
}
